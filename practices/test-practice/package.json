{
  "name": "tea-shop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "migrate:test": "echo 'TODO: add migration command (Stage 5)'",
    "lint": "eslint src --ext .ts,.tsx",
    "format:check": "prettier --check src",
    "format": "prettier --write src",
    "build": "tsc --noEmit",
    "skills:validate": "node scripts/validate-skills.js",
    "skills:index": "node scripts/generate-registry.js",
    "skills:check": "node scripts/validate-skills.js && node scripts/generate-registry.js --check"
  },
  "devDependencies": {
    "@jest/globals": "^29.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  }
}
