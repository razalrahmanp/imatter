{
  "name": "sdlc-tools",
  "owner": {
    "name": "razalrahmanp",
    "email": "system@riddoff.com"
  },
  "plugins": [
    {
      "name": "sdlc-validation",
      "source": "./plugin",
      "description": "SDLC validation enforcement — auto-loads your SDLC_VALIDATION.md at every session start, enforces 10-stage gate checks, and blocks Claude from writing code until the correct gate is PASSED.",
      "version": "1.5.0",
      "author": {
        "name": "razalrahmanp"
      },
      "repository": "https://github.com/razalrahmanp/imatter",
      "homepage": "https://github.com/razalrahmanp/imatter",
      "keywords": ["sdlc", "validation", "gates", "engineering", "process"],
      "category": "productivity",

      "commands": [
        "./skills/"
      ],

      "skills": [
        "./skills/"
      ],

      "agents": [
        "./agents/"
      ],

      "mcpServers": {
        "sdlc-validation": {
          "command": "node",
          "args": ["${CLAUDE_PLUGIN_ROOT}/dist/index.js"],
          "env": {
            "MCP_TRANSPORT": "stdio"
          }
        }
      },

      "hooks": {
        "SessionStart": [
          {
            "hooks": [
              {
                "type": "mcp_tool",
                "server": "sdlc-validation",
                "tool": "sdlc_session_brief",
                "input": {
                  "project_root": "${cwd}"
                },
                "statusMessage": "SDLC: loading session brief..."
              }
            ]
          }
        ],
        "Stop": [
          {
            "hooks": [
              {
                "type": "mcp_tool",
                "server": "sdlc-validation",
                "tool": "update_session_log",
                "input": {
                  "project_root": "${cwd}",
                  "work_done": "Session ended — user did not manually log this session.",
                  "next_step": "Review what was done and update this entry."
                },
                "statusMessage": "SDLC: writing session log entry..."
              }
            ]
          }
        ]
      },

      "permissions": {
        "allow": [
          "mcp__sdlc-validation__load_sdlc_context",
          "mcp__sdlc-validation__check_gate_status",
          "mcp__sdlc-validation__get_project_identity",
          "mcp__sdlc-validation__read_sdlc_section",
          "mcp__sdlc-validation__sdlc_session_brief",
          "mcp__sdlc-validation__log_decision",
          "mcp__sdlc-validation__log_open_item",
          "mcp__sdlc-validation__update_session_log",
          "mcp__sdlc-validation__verify_artifact",
          "mcp__sdlc-validation__init_project"
        ]
      }
    }
  ]
}
