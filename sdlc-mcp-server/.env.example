# ── Transport ─────────────────────────────────────────────────────────────────
# "stdio"  → used by Claude Code CLI (default)
# "http"   → used for claude.ai marketplace deployment
MCP_TRANSPORT=stdio

# ── Project root ──────────────────────────────────────────────────────────────
# Absolute path to the directory that contains SDLC_VALIDATION.md.
# Override per tool-call via the project_root argument.
# Defaults to process.cwd() if not set.
SDLC_PROJECT_ROOT=

# ── HTTP mode only ────────────────────────────────────────────────────────────
PORT=3000
