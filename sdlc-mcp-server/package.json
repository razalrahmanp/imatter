{
  "name": "sdlc-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for SDLC validation enforcement — gate checks, decision logging, session logs",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sdlc-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "cross-env MCP_TRANSPORT=http node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:http": "cross-env MCP_TRANSPORT=http tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.18.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
